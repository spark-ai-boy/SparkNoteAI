# SparkNoteAI 环境变量配置
# 复制此文件为 .env 即可使用
# 开发环境：cp docker/.env.example docker/.env
# 生产环境：复制后修改密码和域名

# ==================== 应用配置 ====================
API_BASE_URL=http://localhost:8000
DEBUG=true

# ==================== 数据库配置 ====================
POSTGRES_USER=sparknoteai
POSTGRES_PASSWORD=sparknoteai123
POSTGRES_DB=sparknoteai
# 本地开发时后端直连 localhost；Docker 内使用 db 主机名
DATABASE_URL=postgresql://sparknoteai:sparknoteai123@localhost:5432/sparknoteai

# ==================== Redis 配置 ====================
REDIS_PASSWORD=sparknoteai123

# ==================== Neo4j 配置 ====================
NEO4J_PASSWORD=sparknoteai123

# ==================== JWT 配置 ====================
# 生成方法：openssl rand -hex 32
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== 加密密钥 ====================
# 生成方法：openssl rand -base64 32
ENCRYPTION_KEY=change-me-in-production

# ==================== CORS 配置 ====================
# 允许的前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:19000,http://localhost:8081,http://localhost:19001,http://localhost:19002,http://127.0.0.1,http://127.0.0.1:80

# ==================== 管理员账号 ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
